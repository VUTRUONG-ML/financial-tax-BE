// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
}

// 1. Users_Profile (Hồ sơ Hộ kinh doanh)
model User {
  id           String   @id @default(cuid())
  phoneNumber  String   @unique @map("phone_number")
  passwordHash String   @map("password_hash")
  role         Role     @default(ADMIN)
  taxCode      String   @unique @map("tax_code")
  businessName String   @map("business_name")
  ownerName    String   @map("owner_name")
  cccdNumber   String   @unique @map("cccd_number")
  provinceCity String   @map("province_city")
  isActive     Boolean  @default(true)

  taxConfigs      TaxConfiguration[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
  products        Product[]

  createdAt    DateTime @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt    DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  @@map("users")
}

model RefreshToken{
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  tokenHash     String    @unique @map("token_hash")
  expiresAt     DateTime  @map("expires_at")
  isRevoked     Boolean   @default(false) @map("is_revoked")
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent") // Trinh duyet - thiet bi su dung
  createdAt     DateTime  @default(now()) @db.Timestamptz(3) @map("created_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

model TaxGroup {
  id                 Int                @id @default(autoincrement())
  groupName          String             @map("group_name")
  minRevenue         Decimal            @map("min_revenue") @db.Decimal(18, 4)
  maxRevenue         Decimal?           @map("max_revenue") @db.Decimal(18, 4) 
  description        String?            @map("description")
  
  taxConfigs  TaxConfiguration[]

  @@map("tax_groups")
}

// 3. Specific_Industries (Danh mục Ngành nghề chi tiết)
model SpecificIndustry {
  id             Int      @id @default(autoincrement())
  industryCode   String?  @unique @map("industry_code")
  industryName   String   @map("industry_name")
  
  vatRate        Decimal  @map("vat_rate") @db.Decimal(5, 4) 
  pitRate        Decimal  @map("pit_rate") @db.Decimal(5, 4)
  isVatReducible Boolean  @default(false) @map("is_vat_reducible")

  taxConfigs   TaxConfiguration[]

  @@map("specific_industries")
}


model TaxConfiguration{
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  industryId        Int           @map("industry_id")
  taxGroupId        Int           @map("tax_group_id")

  applyFromDate     DateTime      @map("apply_from_date")
  applyToDate       DateTime?     @map("apply_to_date")

  vatRateSnapShot   Decimal       @map("vat_rate_snapshot") @db.Decimal(5, 4)
  pitRateSnapShot   Decimal       @map("pit_rate_snapshot") @db.Decimal(5, 4)
  isVatReducible    Boolean       @map("is_vat_reducible") @default(false)

  user              User          @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  industry          SpecificIndustry  @relation(fields: [industryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  taxGroup          TaxGroup         @relation(fields: [taxGroupId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt        DateTime         @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt        DateTime         @updatedAt @db.Timestamptz(3) @map("updated_at")

  @@index([userId, applyToDate])
  @@map("tax_configurations")
}

enum  ActionWrite{
  CREATE
  UPDATE
  DELETE
}
model AuditLog{
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  action          ActionWrite  
  tableName       String        @map("table_name")
  recordId        String        @map("record_id")
  oldValues       Json          @map("old_values")
  newValues       Json          @map("new_values")

  createdAt       DateTime      @default(now())   @db.Timestamptz(3)  @map("created_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@map("audit_logs")
}

// 5. Products (Hàng hóa & Dịch vụ)
model Product {
  id                   Int      @id @default(autoincrement())
  publicId             String   @unique @default(cuid()) @map("public_id")
  userId               String   @map("user_id")

  skuCode              String?  @map("sku_code")
  productName          String   @map("product_name")
  unit                 String
  imageUrl             String?  @map("image_url") @db.Text
  imagePublicId        String?  @map("image_public_id") @db.Text

  sellingPrice         Decimal  @map("selling_price")          @db.Decimal(18, 4)

  openingStockQuantity Int      @default(0) @map("opening_stock_quantity")
  openingStockUnitCost Decimal  @default(0) @map("opening_stock_unit_cost") @db.Decimal(18, 4)
  openingStockValue    Decimal  @default(0) @map("opening_stock_value")     @db.Decimal(18, 4)

  // Cache O(1) — cập nhật qua DB Transaction khi có hóa đơn mua/bán
  currentStock         Int      @default(0) @map("current_stock")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt DateTime @updatedAt      @db.Timestamptz(3) @map("updated_at")

  @@index([userId])
  @@index([publicId])
  @@map("products")
}